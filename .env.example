# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token

# Instagram DM (Graph API — Messenger platform for IG)
# INSTAGRAM_TOKEN: Page Access Token for the Facebook Page linked to your IG Business account
# INSTAGRAM_ACCOUNT_ID: the Instagram Business Account ID (or Page ID, depending on API version)
# INSTAGRAM_VERIFY_TOKEN: any string you pick — Meta will send it back on webhook verification
INSTAGRAM_TOKEN=your_instagram_page_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id
INSTAGRAM_VERIFY_TOKEN=your_custom_verify_token

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (for Whisper voice-to-text)
OPENAI_API_KEY=your_openai_api_key

# Google Sheets
GOOGLE_SHEETS_ID=your_google_sheet_id

# Google Calendar
GOOGLE_CALENDAR_ID=your_calendar_id

# Google Service Account credentials file path
GOOGLE_CREDENTIALS_FILE=credentials.json

# Business Config
BUSINESS_NAME=کلینیک شما
BUSINESS_SERVICES=مشاوره,معاینه,نوبت دکتر
BUSINESS_WORKING_HOURS_START=09:00
BUSINESS_WORKING_HOURS_END=18:00
BUSINESS_APPOINTMENT_DURATION_MINUTES=30
BUSINESS_TIMEZONE=Asia/Tehran
